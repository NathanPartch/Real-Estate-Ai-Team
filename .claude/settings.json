{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(data/**)",
      "Write(docs/**)",
      "Bash(python3 src/tools/*.py)",
      "Bash(cat *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Write(.claude/**)"
    ]
  }
}
